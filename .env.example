# ============================================================
# AgentMarketing — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# AI / Claude
# ------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ------------------------------------------------------------
# Program 1: Social Media
# ------------------------------------------------------------

# Meta (Instagram + Facebook)
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_ACCESS_TOKEN=your_meta_long_lived_access_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id
FACEBOOK_PAGE_ID=your_facebook_page_id

# LinkedIn
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
LINKEDIN_ORGANIZATION_ID=your_linkedin_org_id

# Social Media Scheduling Tool (if applicable)
# e.g. Buffer, Hootsuite, Later, etc.
SOCIAL_SCHEDULER_API_KEY=your_scheduler_api_key

# ------------------------------------------------------------
# Program 2: Commercial Outreach Email Campaign
# ------------------------------------------------------------

# Levitate (current platform — evaluate vs. alternatives)
LEVITATE_API_KEY=your_levitate_api_key
LEVITATE_ACCOUNT_ID=your_levitate_account_id

# Alternative Email Platform (if Levitate is replaced)
# e.g. Instantly, Smartlead, Mailchimp, SendGrid, etc.
EMAIL_PLATFORM_API_KEY=your_email_platform_api_key
EMAIL_PLATFORM_ACCOUNT_ID=your_email_platform_account_id

# Sender identity
OUTREACH_FROM_EMAIL=your_sender_email@yourdomain.com
OUTREACH_FROM_NAME=Your Name or Company

# ------------------------------------------------------------
# Lead Data / CoStar
# ------------------------------------------------------------
# CoStar does not have a public API for contact export.
# If a file-based or manual workflow is used, set the
# drop folder path or storage location here.
LEAD_IMPORT_FOLDER=./data/leads

# ------------------------------------------------------------
# Storage / File Handling (optional)
# ------------------------------------------------------------
# If using cloud storage for assets, leads, or reports
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id
DROPBOX_ACCESS_TOKEN=your_dropbox_access_token

# ------------------------------------------------------------
# Notifications / Escalation
# ------------------------------------------------------------
# For routing qualified leads or alerts to the myNHD sales team
SLACK_WEBHOOK_URL=your_slack_webhook_url
ESCALATION_EMAIL=sales@mynhd.com

# ------------------------------------------------------------
# Reporting (optional)
# ------------------------------------------------------------
# If campaign data is pushed to a reporting tool or database
REPORTING_DB_URL=your_database_connection_string
