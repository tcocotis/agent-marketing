# ============================================================
# AgentMarketing — .gitignore
# ============================================================

# ------------------------------------------------------------
# Secrets & Environment
# ------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
secrets/

# ------------------------------------------------------------
# Data / Leads (never commit raw lead data)
# ------------------------------------------------------------
data/
leads/
exports/
*.csv
*.xlsx
*.xls

# ------------------------------------------------------------
# OS & System Files
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------------------------
# Editor & IDE
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ------------------------------------------------------------
# Node (if any automation tools use npm)
# ------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ------------------------------------------------------------
# Python (if any scripts or agent tools use Python)
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/

# ------------------------------------------------------------
# Logs & Temp Files
# ------------------------------------------------------------
logs/
*.log
tmp/
temp/
.cache/

# ------------------------------------------------------------
# Output / Drafts (keep source docs, not generated outputs)
# ------------------------------------------------------------
outputs/
drafts/

# ------------------------------------------------------------
# Credentials & Auth Tokens
# ------------------------------------------------------------
*.token
credentials.json
token.json
service-account*.json
